ARG RUST_VERSION=1.96.1
ARG GORELEASER_VERSION=2.17.0
ARG RELEASE_TOOLS_VERSION=3.5.0
ARG RELEASE_TOOLS_SHA256=bd2eb0eec47aa2b198d9a3983bb1768572beb5cd8c5824dafcb57bc41cf24d44
FROM docker.io/library/rust:${RUST_VERSION}-bookworm

ARG GORELEASER_VERSION=2.17.0
ARG RELEASE_TOOLS_VERSION=3.5.0
ARG RELEASE_TOOLS_SHA256=bd2eb0eec47aa2b198d9a3983bb1768572beb5cd8c5824dafcb57bc41cf24d44
ARG CARGO_AUDIT_VERSION=0.22.2
ARG CARGO_DENY_VERSION=0.20.2
ARG CARGO_INSTA_VERSION=1.48.0
ARG CARGO_MACHETE_VERSION=0.9.2
ARG CARGO_NEXTEST_VERSION=0.9.140

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    make \
    pkg-config \
 && rm -rf /var/lib/apt/lists/*

RUN rustup component add rustfmt clippy rust-analyzer

RUN cargo install --locked \
    cargo-audit@${CARGO_AUDIT_VERSION} \
    cargo-deny@${CARGO_DENY_VERSION} \
    cargo-machete@${CARGO_MACHETE_VERSION} \
    cargo-nextest@${CARGO_NEXTEST_VERSION}

RUN cargo install --locked cargo-insta@${CARGO_INSTA_VERSION}

RUN curl -fsSL -o /tmp/goreleaser.tar.gz \
    "https://github.com/goreleaser/goreleaser/releases/download/v${GORELEASER_VERSION}/goreleaser_Linux_x86_64.tar.gz" \
 && tar -xzf /tmp/goreleaser.tar.gz -C /usr/local/bin goreleaser \
 && chmod 0755 /usr/local/bin/goreleaser \
 && rm -f /tmp/goreleaser.tar.gz

RUN curl -fsSL -o /usr/local/bin/release-tools \
    "https://codeberg.org/rch/release-tools/releases/download/v${RELEASE_TOOLS_VERSION}/release-tools_${RELEASE_TOOLS_VERSION}_linux_amd64" \
 && printf '%s  %s\n' "${RELEASE_TOOLS_SHA256}" /usr/local/bin/release-tools | sha256sum -c - \
 && chmod 0755 /usr/local/bin/release-tools

RUN chmod -R a+rwX /usr/local/cargo /usr/local/rustup \
 && mkdir -p /workspace \
 && chmod 777 /workspace

WORKDIR /workspace
