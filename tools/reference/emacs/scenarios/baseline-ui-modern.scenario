SCENARIO_NAME=baseline-ui-modern
SCENARIO_DESCRIPTION='Observe modern Emacs screen layout and mode line.'
EMACS_PROFILE=modern
WIDTH=100
HEIGHT=24
FIXTURE_NAME=baseline-ui-modern.txt
FIXTURE_CONTENT=$'alpha\nbeta\ngamma\n'

vhs_steps() {
  cat <<'EOF'
Wait+Screen /alpha/
Sleep 500ms
Screenshot {{FRAME_DIR}}/00-open.png
Sleep 500ms
Ctrl+X
Ctrl+C
EOF
}
