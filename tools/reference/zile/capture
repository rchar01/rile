set -euo pipefail

if (($# != 1)); then
  printf '%s\n' 'usage: tools/reference/zile/capture <scenario-name-or-path>' >&2
  exit 2
fi

root=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../../.." && pwd)
image=${IMAGE:-rile-zile-reference}
podman=${PODMAN:-podman}

"$podman" build \
  -f "$root/tools/reference/zile/Containerfile" \
  -t "$image" \
  "$root"

"$podman" run --rm \
  --userns=keep-id \
  -v "$root":/workspace:z \
  -w /workspace \
  -e REFERENCE_AUTO_PAUSES \
  -e REFERENCE_INPUT_PAUSE \
  -e REFERENCE_SCREENSHOT_PAUSE \
  -e TYPING_SPEED \
  "$image" \
  tools/reference/zile/capture-in-container "$1"
