SCENARIO_NAME=smoke-open
SCENARIO_DESCRIPTION='Open a small fixture in Zile and quit cleanly.'
WIDTH=100
HEIGHT=24
FIXTURE_NAME=smoke-open.txt
FIXTURE_CONTENT=$'alpha reference line\nbeta reference line\n'

vhs_steps() {
  cat <<'EOF'
Wait+Screen /alpha reference line/
Sleep 500ms
Screenshot {{FRAME_DIR}}/00-open.png
Sleep 500ms
Ctrl+X
Ctrl+C
EOF
}
