set -euo pipefail

if (($# != 1)); then
  printf '%s\n' 'usage: tools/reference/zile/capture-in-container <scenario-name-or-path>' >&2
  exit 2
fi

root=/workspace
scenario_arg=$1
scenario_path=$scenario_arg
if [[ $scenario_arg != */* ]]; then
  scenario_path=$root/tools/reference/zile/scenarios/$scenario_arg.scenario
fi

if [[ ! -f "$scenario_path" ]]; then
  printf 'reference scenario not found: %s\n' "$scenario_path" >&2
  exit 1
fi

zile_rel=artifacts/reference/zile/install/bin/zile
zile=$root/$zile_rel
if [[ ! -x "$zile" ]]; then
  printf 'Zile reference binary not found: %s\n' "$zile" >&2
  printf '%s\n' 'Run tools/reference/zile/build first.' >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$scenario_path"

: "${SCENARIO_NAME:?scenario must set SCENARIO_NAME}"
: "${WIDTH:?scenario must set WIDTH}"
: "${HEIGHT:?scenario must set HEIGHT}"
: "${FIXTURE_NAME:?scenario must set FIXTURE_NAME}"
: "${FIXTURE_CONTENT:?scenario must set FIXTURE_CONTENT}"
: "${TYPING_SPEED:=}"
: "${AUTO_INPUT_PAUSES:=1}"
: "${INPUT_PAUSE:=500ms}"
: "${SCREENSHOT_PAUSE:=}"

if ! declare -F vhs_steps >/dev/null; then
  printf 'scenario must define vhs_steps function: %s\n' "$scenario_path" >&2
  exit 1
fi

capture_rel=artifacts/reference/zile/captures/$SCENARIO_NAME
frame_rel=$capture_rel/frames
home_rel=$capture_rel/home
fixture_rel=$capture_rel/$FIXTURE_NAME
gif_rel=$capture_rel/$SCENARIO_NAME.gif

capture_dir=$root/$capture_rel
frame_dir=$root/$frame_rel
home_dir=$root/$home_rel
fixture=$root/$fixture_rel
tape=$capture_dir/$SCENARIO_NAME.tape

rm -rf "$capture_dir"
mkdir -p "$frame_dir" "$home_dir"
mkdir -p "$(dirname "$fixture")"
printf '%s' "$FIXTURE_CONTENT" > "$fixture"

if declare -F setup_reference_files >/dev/null; then
  setup_reference_files "$capture_dir" "$capture_rel"
fi

steps=$(vhs_steps)
steps=${steps//\{\{FRAME_DIR\}\}/$frame_rel}
steps=${steps//\{\{FIXTURE\}\}/$fixture_rel}
steps=${steps//\{\{ZILE\}\}/$zile_rel}
steps=${steps//\{\{HOME\}\}/$home_rel}
effective_input_pause=${REFERENCE_INPUT_PAUSE:-$INPUT_PAUSE}
effective_screenshot_pause=${REFERENCE_SCREENSHOT_PAUSE:-${SCREENSHOT_PAUSE:-$effective_input_pause}}
steps=$(
  REFERENCE_AUTO_PAUSES="${REFERENCE_AUTO_PAUSES:-$AUTO_INPUT_PAUSES}" \
    REFERENCE_INPUT_PAUSE="$effective_input_pause" \
    REFERENCE_SCREENSHOT_PAUSE="$effective_screenshot_pause" \
    bash "$root/tools/reference/lib/expand-vhs-steps" <<<"$steps"
)

typing_speed_line=
if [[ -n $TYPING_SPEED ]]; then
  typing_speed_line="Set TypingSpeed $TYPING_SPEED"
fi

cat > "$tape" <<EOF
Output $gif_rel

Set Width 1280
Set Height 720
Set FontSize 18
Set Padding 12
Set CursorBlink false
$typing_speed_line

Require $zile_rel

Type "stty cols $WIDTH rows $HEIGHT && HOME=$home_rel TERM=xterm-256color $zile_rel --no-init-file $fixture_rel"
Enter
$steps
EOF

vhs validate "$tape"
vhs "$tape"

printf 'Captured Zile reference scenario: %s\n' "$SCENARIO_NAME"
printf 'Artifacts: %s\n' "$capture_dir"
